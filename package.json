{
	"name": "riichi-mahjong",
	"version": "0.1.0",
	"description": "A comprehensive library for riichi mahjong: hand scoring, shanten calculation, agari detection, and game utilities",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsc -p tsconfig.build.json",
		"test": "vitest",
		"test:ui": "vitest --ui",
		"test:run": "vitest run",
		"test:coverage": "vitest run --coverage",
		"lint": "biome lint ./src ./tests",
		"format": "biome format --write ./src ./tests",
		"check": "biome check --write ./src ./tests",
		"typecheck": "tsc --noEmit",
		"prepublishOnly": "npm run build",
		"prepare": "husky"
	},
	"keywords": [
		"mahjong",
		"riichi",
		"japanese-mahjong"
	],
	"author": "k0kishima",
	"license": "MIT",
	"engines": {
		"node": ">=18.0.0"
	},
	"devDependencies": {
		"@biomejs/biome": "2.3.8",
		"@vitest/ui": "^4.0.3",
		"husky": "^9.1.7",
		"lint-staged": "^16.2.7",
		"typescript": "~5.9.0",
		"vitest": "^4.0.3"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/k0kishima/riichi-mahjong.git"
	},
	"lint-staged": {
		"*.{js,ts,cjs,mjs,d.cts,d.mts,json,jsonc}": [
			"biome check --write --no-errors-on-unmatched"
		]
	}
}